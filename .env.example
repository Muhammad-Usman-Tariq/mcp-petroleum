# Master Database (where tokens are stored)
MASTER_DB_HOST=your-mysql-internal-host
MASTER_DB_PORT=3306
MASTER_DB_USER=root
MASTER_DB_PASSWORD=your-password
MASTER_DB_NAME=mcp_master

# Server Config
MCP_PORT=8000
ADMIN_PORT=8001
MCP_BASE_URL=https://your-domain.com

# Admin Panel Secret
ADMIN_SECRET=change-this-to-something-strong